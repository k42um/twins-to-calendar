{
  "manifest_version": 3,
  "name": "TWINS to Calendar",
  "version": "1.0.0",
  "description": "筑波大学のTWINSの履修情報をカレンダーアプリに登録するためのChrome拡張機能",
  "permissions": [
    "scripting",
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://twins.tsukuba.ac.jp/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "TWINS to Calendar",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
